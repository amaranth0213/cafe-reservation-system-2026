# Supabase（https://supabase.com でプロジェクト作成後に取得）
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# 管理者パスワード（bcryptハッシュ）
# 生成方法: node -e "const bcrypt = require('bcryptjs'); console.log(bcrypt.hashSync('あなたのパスワード', 10));"
ADMIN_PASSWORD_HASH=$2b$10$xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
